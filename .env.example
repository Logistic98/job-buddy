# Job Buddy 服务环境变量。
# 本地开发时可复制 .env.example 为 .env，并将示例值替换为实际值。
# .env 已被 Git 忽略；配置发生变化时必须同步维护本文件与 .env.example。

# ===== 公共部署配置 =====
# 浏览器访问服务时使用的主机名或 IP 地址，仅用于生成访问链接。
JOB_BUDDY_SERVER_HOST=127.0.0.1
# 应用服务监听地址；仅在具备防火墙或反向代理保护时设置为 0.0.0.0。
JOB_BUDDY_BIND_HOST=127.0.0.1
# 基础设施服务监听地址；默认仅允许本机访问。
JOB_BUDDY_INFRA_BIND_HOST=127.0.0.1
# Docker Compose 加载的环境变量文件路径。
JOB_BUDDY_ENV_FILE=.env
# 应用服务 Docker Compose 项目名称。
APPLICATION_COMPOSE_PROJECT_NAME=job-buddy
# 基础设施 Docker Compose 项目名称。
INFRASTRUCTURE_COMPOSE_PROJECT_NAME=job-buddy-infrastructure
# 应用与基础设施容器共用的 Docker 网络名称。
JOB_BUDDY_NETWORK_NAME=job-buddy-network
# PostgreSQL 数据持久化使用的 Docker 卷名称。
JOB_BUDDY_POSTGRES_VOLUME_NAME=job-buddy-postgres-data
# Redis 数据持久化使用的 Docker 卷名称。
JOB_BUDDY_REDIS_VOLUME_NAME=job-buddy-redis-data
# MinIO 数据持久化使用的 Docker 卷名称。
JOB_BUDDY_MINIO_VOLUME_NAME=job-buddy-minio-data
# Docker Compose 并行执行任务数量上限，用于减少资源竞争。
COMPOSE_PARALLEL_LIMIT=1
# 是否启用 Docker Compose Bake 构建能力。
COMPOSE_BAKE=false
# Docker 镜像仓库地址。
DOCKER_REGISTRY=docker.io
# Python pip 默认软件包索引地址。
PIP_INDEX_URL=https://pypi.org/simple
# Python uv 默认软件包索引地址。
UV_DEFAULT_INDEX=https://pypi.org/simple
# Node.js npm 默认软件包仓库地址。
NPM_CONFIG_REGISTRY=https://registry.npmjs.org
# Java Maven 默认依赖仓库地址。
MAVEN_REPO_URL=https://repo.maven.apache.org/maven2

# ===== Java 后端服务 =====
# Spring Boot 后端服务监听端口。
SERVER_PORT=8080
# Spring Boot 连接 PostgreSQL 的 JDBC 地址。
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/job_buddy
# Spring Boot 数据库连接用户名。
SPRING_DATASOURCE_USERNAME=job_buddy
# Backend 与 agent-memory 共用的 PostgreSQL 应用数据库名称。
POSTGRES_APP_DB=job_buddy
# Spring Boot 数据库连接密码，请勿提交真实密码。
SPRING_DATASOURCE_PASSWORD=change-me
# Spring Boot 数据源使用的 JDBC 驱动类。
SPRING_DATASOURCE_DRIVER=org.postgresql.Driver
# HikariCP 最大连接数。
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=10
# HikariCP 最小空闲连接数。
SPRING_DATASOURCE_HIKARI_MINIMUM_IDLE=2
# HikariCP 获取连接的超时毫秒数。
SPRING_DATASOURCE_HIKARI_CONNECTION_TIMEOUT=10000
# HikariCP 连接校验的超时毫秒数。
SPRING_DATASOURCE_HIKARI_VALIDATION_TIMEOUT=3000
# HikariCP 空闲连接的回收毫秒数。
SPRING_DATASOURCE_HIKARI_IDLE_TIMEOUT=300000
# HikariCP 单个连接的最大存活毫秒数。
SPRING_DATASOURCE_HIKARI_MAX_LIFETIME=600000
# HikariCP 保活探测间隔毫秒数。
SPRING_DATASOURCE_HIKARI_KEEPALIVE_TIME=120000
# Spring Boot 连接 Redis 的主机地址。
SPRING_REDIS_HOST=127.0.0.1
# Spring Boot 连接 Redis 的端口。
SPRING_REDIS_PORT=6379
# Spring Boot 连接 Redis 的密码，请勿提交真实密码。
SPRING_REDIS_PASSWORD=change-me
# Spring Boot 使用的 Redis 逻辑数据库编号。
SPRING_REDIS_DATABASE=0
# Spring Boot 连接 Redis 的超时时间。
SPRING_REDIS_TIMEOUT=3s
# Spring Boot 单个上传文件的最大允许大小。
SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=1GB
# Spring Boot 单次 multipart 请求的最大允许大小。
SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=1025MB
# 是否启用 Flyway 数据库迁移。
SPRING_FLYWAY_ENABLED=true
# 后端访问 agent-intent 服务的基础地址。
AGENT_INTENT_URL=http://127.0.0.1:8020
# 后端访问 agent-memory 服务的基础地址。
AGENT_MEMORY_URL=http://127.0.0.1:8030
# 后端访问 agent-tool 服务的基础地址。
AGENT_TOOL_URL=http://127.0.0.1:8040
# 后端访问 agent-eval 服务的基础地址。
AGENT_EVAL_URL=http://127.0.0.1:8050
# 后端访问 agent-runtime 服务的基础地址。
AGENT_RUNTIME_URL=http://127.0.0.1:8010
# 后端访问 agent-sandbox 服务的基础地址。
AGENT_SANDBOX_URL=http://127.0.0.1:8061
# 沙箱命令输出允许捕获的最大字节数。
AGENT_SANDBOX_MAX_CAPTURE_BYTES=1048576
# 后端连接各 Agent 服务的超时时间。
AGENT_SERVICE_CONNECT_TIMEOUT=2s
# 后端读取各 Agent 服务响应的超时时间；需大于最长同步 Runtime 工具预算。
AGENT_SERVICE_READ_TIMEOUT=135s
# 后端连接 agent-memory 的独立短超时，避免设置页受通用长任务预算影响。
AGENT_MEMORY_CLIENT_CONNECT_TIMEOUT=2s
# 后端读取 agent-memory 列表和检索响应的单次超时；瞬时失败最多按统一重试预算重试。
AGENT_MEMORY_CLIENT_READ_TIMEOUT=10s
# 后端建立 Agent SSE 上游连接的超时时间。
AGENT_SERVICE_STREAM_CONNECT_TIMEOUT=10s
# 后端读取 Agent SSE 上游事件的超时时间。
AGENT_SERVICE_STREAM_READ_TIMEOUT=180s
# 单个 Agent SSE 会话允许持续的最长时间。
AGENT_SERVICE_STREAM_SESSION_TIMEOUT=15m
# 聊天 SSE 长任务的心跳间隔，必须小于前端 VITE_STREAM_HEARTBEAT_TIMEOUT_MS。
AGENT_SERVICE_STREAM_HEARTBEAT_INTERVAL=10s
AGENT_SERVICE_STREAM_CORE_THREADS=4
AGENT_SERVICE_STREAM_MAX_THREADS=64
AGENT_SERVICE_STREAM_QUEUE_CAPACITY=128
AGENT_SERVICE_STREAM_MAX_GLOBAL=96
AGENT_SERVICE_STREAM_MAX_PER_TENANT=48
AGENT_SERVICE_STREAM_MAX_PER_USER=6
# 后端调用 Agent 服务时包含首次请求在内的最大尝试次数。
AGENT_SERVICE_MAX_ATTEMPTS=2
# Agent 服务瞬时失败后的重试退避时间。
AGENT_SERVICE_RETRY_BACKOFF=200ms
# Agent 服务熔断器进入打开状态前的连续失败阈值。
AGENT_SERVICE_CIRCUIT_FAILURE_THRESHOLD=5
# Agent 服务熔断器打开后的冷却时间。
AGENT_SERVICE_CIRCUIT_OPEN_DURATION=15s
# 未显式指定用户时使用的默认用户标识。
JOB_BUDDY_DEFAULT_USER_ID=job_buddy_user
# 是否启用 Job Buddy 用户认证。
JOB_BUDDY_AUTH_ENABLED=true
# 仅供受控内部兼容接口使用的后端令牌；没有兼容调用方时保持为空。
JOB_BUDDY_INTERNAL_API_TOKEN=
# 资源预览地址的签名密钥；生产环境必须注入独立高强度密钥。
JOB_BUDDY_ASSET_URL_SIGNING_KEY=
# 资源预览签名地址的有效秒数。
JOB_BUDDY_ASSET_URL_TTL_SECONDS=3600
# 允许携带认证信息访问后端的前端 Origin，多个值使用英文逗号分隔。
JOB_BUDDY_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# 用于加密持久化 Boss 凭据的 Base64 编码 32 字节 AES 密钥。
JOB_BUDDY_BOSS_CREDENTIAL_ENCRYPTION_KEY=
# 是否启用高风险意图安全门禁；完成浏览器端到端验证前应保持关闭。
JOB_BUDDY_INTENT_SAFETY_GATE_ENABLED=false
# 单次岗位推荐允许返回的最大岗位数量。
JOB_BUDDY_MAX_JOBS_PER_RECOMMEND=15
# 单轮简历匹配允许进入评分阶段的最大岗位数量。
JOB_BUDDY_MAX_JOBS_PER_SCORING=80
# 岗位推荐候选池相对展示数量的扩展倍率。
JOB_BUDDY_RECOMMEND_OVERFETCH_FACTOR=5
# 完成简历匹配后允许进入推荐结果的最低分数。
JOB_BUDDY_MINIMUM_RECOMMENDED_MATCH_SCORE=60
# Boss 原岗位页面使用的公开 Web 基础地址。
JOB_BUDDY_BOSS_WEB_BASE_URL=https://www.zhipin.com
# Redis 故障后聊天缓存暂停探测的冷却时间。
CHAT_REDIS_FAILURE_COOLDOWN=30s
# 简历文件允许上传的最大字节数。
JOB_BUDDY_MAX_RESUME_BYTES=5242880
# 每个用户保留的简历撰写版本数量。
JOB_BUDDY_RESUME_WRITER_VERSION_LIMIT=30
# 简历处理任务使用的 Runtime 工作目录。
JOB_BUDDY_RESUME_RUNTIME_WORKSPACE=.run/runtime-workspace
# 后端访问 MinIO 或兼容 S3 服务的地址。
JOB_BUDDY_MINIO_ENDPOINT=https://minio.example.com
# MinIO 访问密钥标识，请勿提交真实凭据。
JOB_BUDDY_MINIO_ACCESS_KEY=example-access-key
# MinIO 访问密钥，请勿提交真实凭据。
JOB_BUDDY_MINIO_SECRET_KEY=example-secret-key
# 存储 Job Buddy 文件的 MinIO Bucket 名称。
JOB_BUDDY_MINIO_BUCKET=job-buddy
# MinIO 或兼容 S3 服务所在区域，可按服务要求留空。
JOB_BUDDY_MINIO_REGION=us-east-1
# 是否使用 HTTPS 连接 MinIO。
JOB_BUDDY_MINIO_SECURE=true
# MinIO 或兼容 S3 请求使用的签名版本。
JOB_BUDDY_MINIO_SIGNATURE_VERSION=v4

# ===== Agent Runtime 服务 =====
# agent-runtime 主配置文件路径。
JOB_BUDDY_CONFIG=config/config.yaml
# 大语言模型 OpenAI 兼容接口地址。
JOB_BUDDY_LLM_BASE_URL=https://api.example.com/v1/chat/completions
# 大语言模型服务 API Key，请勿提交真实密钥。
JOB_BUDDY_LLM_API_KEY=sk-example
# agent-runtime 默认使用的模型名称。
JOB_BUDDY_LLM_MODEL_NAME=example-model
# 单次大语言模型请求超时秒数。
JOB_BUDDY_LLM_TIMEOUT_SECONDS=120
# 大语言模型请求失败后的最大重试次数。
JOB_BUDDY_LLM_MAX_RETRIES=2
# 大语言模型重试的基础退避秒数。
JOB_BUDDY_LLM_RETRY_BACKOFF_SECONDS=0.8
# 大语言模型生成温度，数值越低结果越稳定。
JOB_BUDDY_LLM_TEMPERATURE=0.2
# 单次大语言模型响应允许生成的最大 Token 数。
JOB_BUDDY_LLM_MAX_TOKENS=4096
# 是否启用大语言模型 Prompt 缓存。
JOB_BUDDY_LLM_PROMPT_CACHE_ENABLED=true
# 是否启用 Runtime 工具搜索与按需加载。
JOB_BUDDY_TOOL_SEARCH_ENABLED=true
# agent-runtime 应用名称，用于标识运行实例。
JOB_BUDDY_RUNTIME_APP_NAME=job_buddy_runtime
# 单次 Agent Loop 允许执行的最大轮数。
JOB_BUDDY_RUNTIME_MAX_TURNS=12
# 单次任务允许发起的最大工具调用次数。
JOB_BUDDY_RUNTIME_MAX_TOOL_CALLS=20
# 单次任务允许累计的最大失败次数。
JOB_BUDDY_RUNTIME_MAX_FAILURES=3
# 单次 Runtime 任务允许消耗的最大生成 Token 数；直接流式响应同样受此上限约束。
JOB_BUDDY_RUNTIME_MAX_TOKENS=32768
# Runtime 调用单个工具的超时秒数。
JOB_BUDDY_RUNTIME_TOOL_TIMEOUT_SECONDS=30
# 是否使用大语言模型生成任务执行计划。
JOB_BUDDY_RUNTIME_USE_LLM_PLANNER=true
# agent-runtime 执行任务时使用的工作目录。
JOB_BUDDY_RUNTIME_WORKSPACE_DIR=.run/runtime-workspace
# 是否允许 API 客户端请求自动权限模式；非隔离调试环境应关闭。
JOB_BUDDY_ALLOW_AUTO_PERMISSION_MODE=false
# 是否允许 API 客户端绕过权限模式；非隔离调试环境应关闭。
JOB_BUDDY_ALLOW_BYPASS_PERMISSION_MODE=false
# 是否启用高风险工具调用的独立 transcript 复核。
JOB_BUDDY_TRANSCRIPT_REVIEW_ENABLED=true
# Runtime 调用 agent-intent transcript 复核接口的基础地址。
JOB_BUDDY_TRANSCRIPT_REVIEW_BASE_URL=http://127.0.0.1:8020
# transcript 复核请求超时秒数。
JOB_BUDDY_TRANSCRIPT_REVIEW_TIMEOUT_SECONDS=2
# transcript 复核因超时、连接失败、限流或服务端错误时的最大重试次数。
JOB_BUDDY_TRANSCRIPT_REVIEW_MAX_RETRIES=1
# transcript 复核重试的基础退避秒数。
JOB_BUDDY_TRANSCRIPT_REVIEW_RETRY_BACKOFF_SECONDS=0.2
# agent-runtime 的 Loguru 日志级别，可选 DEBUG、INFO、WARNING 或 ERROR。
LOG_LEVEL=INFO
# Runtime 安全检查使用的部署环境名称，例如 development、production 或 prod。
JOB_BUDDY_ENVIRONMENT=development
# 服务间调用使用的共享令牌；生产环境及 Sandbox 非回环监听（包括应用 Compose）必须设置。
AGENT_INTERNAL_SERVICE_TOKEN=
# 是否在 Runtime 上下文装配阶段启用长期记忆检索。
JOB_BUDDY_MEMORY_ENABLED=true
# Runtime 访问 agent-memory 服务的基础地址。
JOB_BUDDY_MEMORY_BASE_URL=http://127.0.0.1:8030
# Runtime 调用 agent-memory 服务的超时秒数。
JOB_BUDDY_MEMORY_TIMEOUT_SECONDS=3.0
# 每次长期记忆检索注入上下文的最大条目数。
JOB_BUDDY_MEMORY_TOP_K=5
# 未显式指定时使用的默认记忆作用域。
JOB_BUDDY_MEMORY_DEFAULT_SCOPE=long_term

# ===== Agent Intent 服务 =====
# 低于该置信度且非高风险的分类结果必须请求用户澄清。
AGENT_INTENT_CLARIFY_CONFIDENCE_THRESHOLD=0.5
# 是否启用 agent-intent 的 LLM 长尾分类器。
AGENT_INTENT_LLM_ENABLED=false
# Intent LLM 使用的 OpenAI 兼容接口地址；未启用时保持为空。
AGENT_INTENT_LLM_BASE_URL=
# Intent LLM 服务 API Key；请勿提交真实密钥。
AGENT_INTENT_LLM_API_KEY=
# Intent LLM 模型名称；未启用时保持为空。
AGENT_INTENT_LLM_MODEL=
# Intent LLM 单次请求超时秒数。
AGENT_INTENT_LLM_TIMEOUT_SECONDS=8
# Intent LLM 请求失败后的最大重试次数。
AGENT_INTENT_LLM_MAX_RETRIES=1

# ===== Agent Eval 服务 =====
# LLM Judge 使用的 OpenAI 兼容接口地址；地址或模型为空时 Judge 保持关闭。
AGENT_EVAL_JUDGE_BASE_URL=
# LLM Judge 服务 API Key；请勿提交真实密钥。
AGENT_EVAL_JUDGE_API_KEY=
# LLM Judge 使用的模型名称。
AGENT_EVAL_JUDGE_MODEL=
# LLM Judge 单次请求超时秒数。
AGENT_EVAL_JUDGE_TIMEOUT_SECONDS=30

# ===== Agent Tool 服务 =====
# agent-tool 独立 Redis 地址；留空时复用 SPRING_REDIS_* 组装连接地址。
AGENT_TOOL_REDIS_URL=
# Boss 限速状态专用 Redis 地址；留空时回退到 AGENT_TOOL_REDIS_URL。
BOSS_CLI_RATE_REDIS_URL=
# agent-tool 访问 agent-memory 服务的基础地址。
AGENT_TOOL_MEMORY_BASE_URL=http://127.0.0.1:8030
# agent-tool 调用 agent-memory 服务的超时秒数。
AGENT_TOOL_MEMORY_TIMEOUT_SECONDS=5
# agent-tool 访问 agent-sandbox 服务的基础地址。
AGENT_TOOL_SANDBOX_BASE_URL=http://127.0.0.1:8061
# agent-tool 调用 agent-sandbox 服务的超时秒数。
AGENT_TOOL_SANDBOX_TIMEOUT_SECONDS=60

# ===== Agent Sandbox 服务 =====
# agent-sandbox 允许并发执行的最大任务数。
AGENT_SANDBOX_MAX_CONCURRENCY=4
# agent-sandbox 单个结果允许返回的最大字符数。
AGENT_SANDBOX_MAX_OUTPUT_CHARS=200000
# srt 可执行文件路径；留空时启动脚本自动发现。
AGENT_SANDBOX_SRT_BIN=
# 沙箱允许访问的工作区；留空时仅允许系统临时目录。
AGENT_SANDBOX_WORKSPACE_DIR=

# ===== 服务发布端口 =====
# PostgreSQL 对宿主机发布的端口。
POSTGRES_PORT=5432
# Redis 对宿主机发布的端口。
REDIS_PORT=6379
# MinIO API 对宿主机发布的端口。
MINIO_API_PORT=9000
# MinIO 管理控制台对宿主机发布的端口。
MINIO_CONSOLE_PORT=9001
# Java 后端服务对宿主机发布的端口。
BACKEND_PORT=8080
# 前端开发或静态服务对宿主机发布的端口。
FRONTEND_PORT=5173
# agent-runtime 对宿主机发布的端口。
RUNTIME_PORT=8010
# agent-intent 对宿主机发布的端口。
INTENT_PORT=8020
# agent-memory 对宿主机发布的端口。
MEMORY_PORT=8030
# agent-tool 对宿主机发布的端口。
TOOL_PORT=8040
# agent-eval 对宿主机发布的端口。
EVAL_PORT=8050
# agent-sandbox 对宿主机发布的端口。
SANDBOX_PORT=8061

# ===== Boss 直聘按需工具 =====
# 是否自动从本机浏览器导入 Boss Cookie；关闭可避免触发系统钥匙串授权。
BOSS_CLI_AUTO_IMPORT_BROWSER_COOKIES=false
# 启用 Cookie 自动导入时使用的浏览器来源。
BOSS_CLI_COOKIE_SOURCE=chrome
# Boss CLI 单次交互请求的超时秒数。
BOSS_CLI_TIMEOUT_SECONDS=20
# Boss CLI 单次请求允许的最大重试次数。
BOSS_CLI_MAX_RETRIES=2
# 状态检查时是否发起真实 Boss 网络请求；默认关闭以减少访问频率。
BOSS_CLI_STATUS_VERIFY=false
# Boss CLI 岗位搜索允许访问的最大页码；单轮抓取页数由 BOSS_SEARCH_MAX_PAGES 单独限制。
BOSS_CLI_MAX_SEARCH_PAGE=5
# Boss CLI 连续请求之间的基础延迟秒数。
BOSS_CLI_REQUEST_DELAY_SECONDS=1.2
# 工具层每小时允许执行的岗位搜索次数。
BOSS_CLI_SEARCH_PER_HOUR=15
# 工具层每天允许执行的岗位搜索次数。
BOSS_CLI_SEARCH_PER_DAY=120
# 工具层每小时允许加载的岗位详情次数。
BOSS_CLI_DETAIL_PER_HOUR=12
# 工具层每天允许加载的岗位详情次数。
BOSS_CLI_DETAIL_PER_DAY=60
# 感兴趣岗位列表的每小时本地硬配额；0 表示不额外设置。
BOSS_CLI_FAVORITE_LIST_PER_HOUR=0
# 感兴趣岗位列表的每日本地硬配额；0 表示不额外设置。
BOSS_CLI_FAVORITE_LIST_PER_DAY=0
# 感兴趣岗位列表调用使用的协议标签。
BOSS_CLI_FAVORITE_LIST_TAG=4
# 感兴趣岗位列表允许访问的最大页码；0 表示不额外设置。
BOSS_CLI_MAX_FAVORITE_LIST_PAGE=0
# Boss 请求随机延迟的最小毫秒数。
BOSS_CLI_DELAY_MIN_MS=1500
# Boss 请求随机延迟的最大毫秒数。
BOSS_CLI_DELAY_MAX_MS=4000
# 工具层检测到风险后进入冷却状态的分钟数。
BOSS_CLI_COOLDOWN_MINUTES=30
# 扫码后是否允许一次性 headless Chromium 补齐 Web 安全 Cookie。
BOSS_CLI_HEADLESS_COOKIE=true
# 一次性 headless Cookie 补齐流程的超时毫秒数。
BOSS_CLI_HEADLESS_COOKIE_TIMEOUT_MS=8000
# Backend 缓存 Boss 登录状态的毫秒数。
BOSS_AUTH_STATUS_CACHE_TTL_MS=300000
# 岗位推荐时是否额外逐条加载详情；默认关闭以控制访问频率。
BOSS_RECOMMEND_ENRICH_DETAILS=false
# 单次岗位搜索流程允许处理的最大页数。
BOSS_SEARCH_MAX_PAGES=2
# 同一检索条件允许访问的最大 Boss 页码。
BOSS_SEARCH_MAX_PAGE_DEPTH=5
# 单次岗位搜索希望收集的候选岗位数量。
BOSS_SEARCH_TARGET_CANDIDATES=15
# 岗位搜索翻页之间的等待毫秒数。
BOSS_SEARCH_PAGE_DELAY_MILLIS=5000
# 岗位搜索结果缓存的有效分钟数。
BOSS_SEARCH_CACHE_TTL_MINUTES=30
# 岗位搜索检测到风控信号后的冷却分钟数。
BOSS_SEARCH_COOLDOWN_MINUTES_ON_RISK=30
# 构建岗位候选池的整体超时秒数，应覆盖请求重试及限流开销。
BOSS_SEARCH_CANDIDATE_POOL_TIMEOUT_SECONDS=50

# ===== 腾讯云 Agent Memory 网关 =====
# 腾讯云 Agent Memory 网关地址；自托管模式可直接指向本地服务。
TDAI_MEMORY_GATEWAY_URL=http://127.0.0.1:8420
# 腾讯云 Agent Memory 网关 API Key；无需认证时可留空。
TDAI_GATEWAY_API_KEY=example-gateway-api-key
# 网关失败后暂停再次探测的冷却秒数。
TDAI_MEMORY_GATEWAY_COOLDOWN_SECONDS=60

# ===== 博查网页搜索 =====
# 博查搜索服务 API Key，请勿提交真实密钥。
BOCHA_API_KEY=sk-example
# 博查网页搜索接口地址。
BOCHA_WEB_SEARCH_ENDPOINT=https://api.bochaai.com/v1/web-search
# 博查搜索结果的时间范围限制。
BOCHA_SEARCH_FRESHNESS=noLimit
# Job Buddy 默认使用的网页搜索提供方。
JOB_BUDDY_WEB_SEARCH_PROVIDER=bocha
# 主搜索提供方失败时是否回退到 DuckDuckGo。
JOB_BUDDY_WEB_SEARCH_FALLBACK_TO_DUCKDUCKGO=true
# Web Fetch 传输、解码、压缩扩张和文本输出预算。
JOB_BUDDY_WEB_FETCH_MAX_WIRE_BYTES=524288
JOB_BUDDY_WEB_FETCH_MAX_DECODED_BYTES=1048576
JOB_BUDDY_WEB_FETCH_MAX_EXPANSION_RATIO=20
JOB_BUDDY_WEB_FETCH_MAX_TEXT_CHARS=24000
JOB_BUDDY_WEB_FETCH_CHUNK_BYTES=16384
# 单个 MCP 服务的目录和结果资源预算。
JOB_BUDDY_MCP_MAX_TOOLS_PER_SERVER=128
JOB_BUDDY_MCP_MAX_CATALOG_BYTES=524288
JOB_BUDDY_MCP_MAX_TOOL_NAME_CHARS=128
JOB_BUDDY_MCP_MAX_TOOL_DESCRIPTION_CHARS=4096
JOB_BUDDY_MCP_MAX_SCHEMA_BYTES=65536
JOB_BUDDY_MCP_MAX_SCHEMA_NODES=2048
JOB_BUDDY_MCP_MAX_SCHEMA_DEPTH=16
JOB_BUDDY_MCP_MAX_RESULT_BYTES=1048576
JOB_BUDDY_MCP_MAX_RESULT_ITEMS=256
JOB_BUDDY_MCP_MAX_RESULT_NODES=8192
JOB_BUDDY_MCP_MAX_RESULT_DEPTH=32

# ===== Agent Memory PostgreSQL 持久化 =====
# agent-runtime Checkpoint 连接 PostgreSQL 的完整数据库地址。
AGENT_RUNTIME_DATABASE_URL=postgresql://job_buddy:change-me@localhost:5432/job_buddy
# agent-memory 连接 PostgreSQL 的完整数据库地址。
AGENT_MEMORY_DATABASE_URL=postgresql://job_buddy:change-me@localhost:5432/job_buddy
# agent-memory 连接 PostgreSQL 使用的 SSL 模式；生产环境建议 require 或 verify-full。
AGENT_MEMORY_DB_SSL_MODE=disable
# agent-memory PostgreSQL 连接池大小。
AGENT_MEMORY_DB_POOL_SIZE=5
# agent-memory 单条 PostgreSQL 命令的超时秒数。
AGENT_MEMORY_DB_CMD_TIMEOUT=5
# agent-memory 启动时遇到瞬时 PostgreSQL 连接故障的最大尝试次数。
AGENT_MEMORY_DB_CONNECT_ATTEMPTS=4
# agent-memory 单次 PostgreSQL 建连的超时秒数。
AGENT_MEMORY_DB_CONNECT_TIMEOUT_SECONDS=8
# agent-memory PostgreSQL 建连重试的指数退避基数秒数。
AGENT_MEMORY_DB_CONNECT_BACKOFF_SECONDS=0.5
# agent-memory 单次相关性搜索最终返回的最大条目数。
AGENT_MEMORY_SEARCH_TOP_K=10
# agent-memory 相关性排序前使用的候选池大小。
AGENT_MEMORY_SEARCH_POOL=200
# 记忆时效衰减计算使用的半衰期天数。
AGENT_MEMORY_SEARCH_HALF_LIFE_DAYS=30
# 是否启用 OpenAI 兼容 Embedding 作为第三路检索信号。
AGENT_MEMORY_EMBEDDING_ENABLED=false
# Embedding 接口地址；未启用时保持为空。
AGENT_MEMORY_EMBEDDING_BASE_URL=
# Embedding 服务 API Key；请勿提交真实密钥。
AGENT_MEMORY_EMBEDDING_API_KEY=
# Embedding 模型名称。
AGENT_MEMORY_EMBEDDING_MODEL=
# Embedding 单次请求超时秒数。
AGENT_MEMORY_EMBEDDING_TIMEOUT_SECONDS=5
# 向量信号参与融合的最小相似度。
AGENT_MEMORY_VECTOR_MIN_SIMILARITY=0.3

# ===== 前端应用 =====
# 前端请求后端 API 时使用的基础路径。
VITE_API_BASE=/api
# Vite 开发服务器代理请求的后端目标地址。
VITE_PROXY_TARGET=http://localhost:8080
# SSE 流中断后是否自动重新连接。
VITE_STREAM_RECONNECT=false
# SSE 流连接失败后的最大重试次数。
VITE_STREAM_RETRY_MAX=4
# SSE 流首次重试的基础等待毫秒数。
VITE_STREAM_RETRY_BASE_DELAY_MS=500
# SSE 流指数退避允许的最大等待毫秒数。
VITE_STREAM_RETRY_MAX_DELAY_MS=5000
# SSE 流未收到心跳时判定超时的毫秒数。
VITE_STREAM_HEARTBEAT_TIMEOUT_MS=30000
# 前端轮询分析任务状态的间隔毫秒数。
VITE_ANALYSIS_TASK_POLL_DELAY_MS=1500
