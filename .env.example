# Job Buddy server environment variables.
# Copy this file to .env for local development and replace example values with real values.
# .env is intentionally ignored by git. Keep this example file synchronized with .env whenever configuration changes.

# Common server address
JOB_BUDDY_SERVER_HOST=127.0.0.1

# agent-backend
SERVER_PORT=8080
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/job_buddy
SPRING_DATASOURCE_USERNAME=job_buddy
SPRING_DATASOURCE_PASSWORD=change-me
SPRING_DATASOURCE_DRIVER=org.postgresql.Driver
SPRING_REDIS_HOST=127.0.0.1
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=change-me
SPRING_REDIS_DATABASE=0
SPRING_REDIS_TIMEOUT=3s
SPRING_FLYWAY_ENABLED=true
AGENT_INTENT_URL=http://127.0.0.1:8020
AGENT_MEMORY_URL=http://127.0.0.1:8030
AGENT_TOOL_URL=http://127.0.0.1:8040
AGENT_EVAL_URL=http://127.0.0.1:8050
AGENT_RUNTIME_URL=http://127.0.0.1:8010
AGENT_SANDBOX_URL=http://127.0.0.1:8061
AGENT_SERVICE_CONNECT_TIMEOUT=2s
AGENT_SERVICE_READ_TIMEOUT=75s
JOB_BUDDY_DEFAULT_USER_ID=job_buddy_user
# High-risk intent safety gate. Keep false until browser E2E verification is done; when true,
# agent-intent high-risk reject predictions are blocked independently before the runtime path.
JOB_BUDDY_INTENT_SAFETY_GATE_ENABLED=false
JOB_BUDDY_MAX_JOBS_PER_RECOMMEND=15
JOB_BUDDY_MAX_RESUME_BYTES=5242880
JOB_BUDDY_RESUME_RUNTIME_WORKSPACE=.run/runtime-workspace
JOB_BUDDY_MINIO_ENDPOINT=https://minio.example.com
JOB_BUDDY_MINIO_ACCESS_KEY=example-access-key
JOB_BUDDY_MINIO_SECRET_KEY=example-secret-key
JOB_BUDDY_MINIO_BUCKET=job-buddy
JOB_BUDDY_MINIO_REGION=us-east-1
JOB_BUDDY_MINIO_SECURE=true

# agent-runtime
JOB_BUDDY_CONFIG=config/config.yaml
JOB_BUDDY_LLM_BASE_URL=https://api.example.com/v1/chat/completions
JOB_BUDDY_LLM_API_KEY=sk-example
JOB_BUDDY_LLM_MODEL_NAME=example-model
JOB_BUDDY_LLM_TIMEOUT_SECONDS=120
JOB_BUDDY_LLM_MAX_RETRIES=2
JOB_BUDDY_LLM_RETRY_BACKOFF_SECONDS=0.8
JOB_BUDDY_LLM_TEMPERATURE=0.2
JOB_BUDDY_LLM_MAX_TOKENS=4096
JOB_BUDDY_LLM_PROMPT_CACHE_ENABLED=true
JOB_BUDDY_LLM_TOOL_SEARCH_ENABLED=true
JOB_BUDDY_RUNTIME_APP_NAME=job_buddy_runtime
JOB_BUDDY_RUNTIME_MAX_TURNS=12
JOB_BUDDY_RUNTIME_MAX_TOOL_CALLS=20
JOB_BUDDY_RUNTIME_MAX_FAILURES=3
JOB_BUDDY_RUNTIME_TOOL_TIMEOUT_SECONDS=30
JOB_BUDDY_RUNTIME_USE_LLM_PLANNER=true
JOB_BUDDY_RUNTIME_WORKSPACE_DIR=.run/runtime-workspace
JOB_BUDDY_RUNTIME_RESULT_STORAGE_DIR=.run/runtime-results
# Long-term memory injection into context assembly. Enabled here so a full local stack
# actually exercises the memory path; retrieval failures degrade silently. Set false to disable.
JOB_BUDDY_MEMORY_ENABLED=true
JOB_BUDDY_MEMORY_BASE_URL=http://127.0.0.1:8030
JOB_BUDDY_MEMORY_TIMEOUT_SECONDS=3.0
JOB_BUDDY_MEMORY_TOP_K=5
JOB_BUDDY_MEMORY_DEFAULT_SCOPE=session

# Local script port overrides
BACKEND_PORT=8080
FRONTEND_PORT=5173
RUNTIME_PORT=8010
INTENT_PORT=8020
MEMORY_PORT=8030
TOOL_PORT=8040
EVAL_PORT=8050
SANDBOX_PORT=8061

# Boss on-demand tool
# Boss implementation lives in agent-tool; agent-runtime only proxies tool invocation.
# The implementation uses jackwener/boss-cli and stores credentials under BOSS_CLI_HOME.
BOSS_CLI_HOME=.run/boss-cli-home
# Keep false for ordinary status checks to avoid macOS Keychain prompts for Chrome Safe Storage.
# Search auth failures will try one throttled browser-cookie refresh; call refresh_auth to force it manually.
BOSS_CLI_AUTO_IMPORT_BROWSER_COOKIES=false
# Optional browser cookie source when auto import is enabled: chrome / firefox / edge / brave / arc / chromium / vivaldi / opera.
BOSS_CLI_COOKIE_SOURCE=chrome
# Keep false by default: status checks should not become repeated real Boss traffic.
BOSS_CLI_STATUS_VERIFY=false
BOSS_CLI_MAX_SEARCH_PAGE=1
BOSS_CLI_REQUEST_DELAY_SECONDS=1.2
BOSS_CLI_TIMEOUT_SECONDS=30
# Tool-layer rate limit and risk cooldown. Names are kept for compatibility.
BOSS_BROWSER_SEARCH_PER_HOUR=15
BOSS_BROWSER_DETAIL_PER_HOUR=12
BOSS_BROWSER_DELAY_MIN_MS=1500
BOSS_BROWSER_DELAY_MAX_MS=4000
BOSS_BROWSER_COOLDOWN_MINUTES=30
BOSS_SEARCH_MAX_PAGES=1
BOSS_SEARCH_TARGET_CANDIDATES=15
BOSS_SEARCH_PAGE_DELAY_MILLIS=5000
BOSS_SEARCH_CACHE_TTL_MINUTES=30
BOSS_SEARCH_COOLDOWN_MINUTES_ON_RISK=30
BOSS_SEARCH_CANDIDATE_POOL_TIMEOUT_SECONDS=30

# agent-memory TencentDB gateway adapter
# Self-hosted TencentDB Agent Memory can run without gateway auth. Leave empty to omit Authorization.
TDAI_MEMORY_GATEWAY_URL=http://127.0.0.1:8420
TDAI_GATEWAY_API_KEY=example-gateway-api-key

# Bocha Search API
BOCHA_API_KEY=sk-example
BOCHA_WEB_SEARCH_ENDPOINT=https://api.bochaai.com/v1/web-search
BOCHA_SEARCH_FRESHNESS=noLimit
JOB_BUDDY_WEB_SEARCH_PROVIDER=bocha
JOB_BUDDY_WEB_SEARCH_FALLBACK_TO_DUCKDUCKGO=true

# agent-memory PostgreSQL local persistence
AGENT_MEMORY_DATABASE_URL=postgresql://job_buddy:change-me@localhost:5432/job_buddy
AGENT_MEMORY_DB_POOL_SIZE=5
# agent-memory relevance-ranked search tuning
AGENT_MEMORY_SEARCH_TOP_K=10
AGENT_MEMORY_SEARCH_POOL=200
AGENT_MEMORY_SEARCH_HALF_LIFE_DAYS=30
